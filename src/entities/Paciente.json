{
  "name": "Paciente",
  "type": "object",
  "properties": {
    "unidade_saude": {
      "type": "string",
      "description": "Nome da unidade de sa\u00fade que est\u00e1 realizando o atendimento"
    },
    "nome_completo": {
      "type": "string",
      "description": "Nome completo do paciente"
    },
    "idade": {
      "type": "number",
      "description": "Idade do paciente"
    },
    "sexo": {
      "type": "string",
      "enum": [
        "Masculino",
        "Feminino"
      ],
      "description": "Sexo do paciente"
    },
    "prontuario": {
      "type": "string",
      "description": "N\u00famero do prontu\u00e1rio"
    },
    "data_hora_chegada": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora de chegada do paciente"
    },
    "data_hora_inicio_sintomas": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora do in\u00edcio dos sintomas"
    },
    "data_hora_inicio_triagem": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora do in\u00edcio da triagem"
    },
    "triagem_cardiologica": {
      "type": "object",
      "description": "Respostas da triagem cardiol\u00f3gica",
      "properties": {
        "dor_desconforto_peito": {
          "type": "boolean"
        },
        "duracao_maior_10min": {
          "type": "boolean"
        },
        "irradiacao": {
          "type": "boolean"
        },
        "dor_epigastrica": {
          "type": "boolean"
        },
        "dispneia_diaforese": {
          "type": "boolean"
        },
        "idade_fatores_risco": {
          "type": "boolean"
        },
        "alerta_iam": {
          "type": "boolean",
          "description": "Se true, emite alerta de prov\u00e1vel IAM"
        }
      }
    },
    "dados_vitais": {
      "type": "object",
      "properties": {
        "pa_braco_esquerdo": {
          "type": "string",
          "description": "Press\u00e3o arterial bra\u00e7o esquerdo (mmHg)"
        },
        "pa_braco_direito": {
          "type": "string",
          "description": "Press\u00e3o arterial bra\u00e7o direito (mmHg)"
        },
        "frequencia_cardiaca": {
          "type": "number",
          "description": "Frequ\u00eancia card\u00edaca (bpm)"
        },
        "frequencia_respiratoria": {
          "type": "number",
          "description": "Frequ\u00eancia respirat\u00f3ria (irpm)"
        },
        "temperatura": {
          "type": "number",
          "description": "Temperatura (\u00b0C)"
        },
        "spo2": {
          "type": "number",
          "description": "SpO2 (%)"
        },
        "spo2_oxigenio": {
          "type": "string",
          "enum": [
            "ar_ambiente",
            "o2_suplementar"
          ],
          "default": "ar_ambiente",
          "description": "Se paciente est\u00e1 em ar ambiente ou usando O2 suplementar"
        },
        "spo2_litros_o2": {
          "type": "number",
          "description": "Litros de O2 por minuto (se estiver usando O2 suplementar)"
        },
        "diabetes": {
          "type": "boolean"
        },
        "dpoc": {
          "type": "boolean"
        },
        "glicemia_capilar": {
          "type": "number",
          "description": "Glicemia capilar (mg/dL)"
        }
      }
    },
    "dados_vitais_medico": {
      "type": "object",
      "description": "Dados vitais atualizados pelo m\u00e9dico na avalia\u00e7\u00e3o",
      "properties": {
        "pa_braco_esquerdo": {
          "type": "string"
        },
        "pa_braco_direito": {
          "type": "string"
        },
        "frequencia_cardiaca": {
          "type": "number"
        },
        "frequencia_respiratoria": {
          "type": "number"
        },
        "temperatura": {
          "type": "number"
        },
        "spo2": {
          "type": "number"
        },
        "glicemia_capilar": {
          "type": "number"
        },
        "suporte_respiratorio": {
          "type": "string",
          "enum": [
            "ar_ambiente",
            "oxigenio_suplementar",
            "ventilacao_mecanica"
          ],
          "description": "Tipo de suporte respirat\u00f3rio"
        },
        "litros_o2": {
          "type": "number",
          "description": "Litros de O2 por minuto se em uso de oxig\u00eanio"
        },
        "uso_dva": {
          "type": "boolean",
          "description": "Uso de drogas vasoativas"
        },
        "dva_tipo": {
          "type": "string",
          "description": "Tipo de DVA em uso (noradrenalina, dobutamina, etc)"
        },
        "uso_sedacao": {
          "type": "boolean",
          "description": "Uso de seda\u00e7\u00e3o"
        },
        "sedacao_tipo": {
          "type": "string",
          "description": "Tipo de seda\u00e7\u00e3o em uso"
        }
      }
    },
    "ecg_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs dos arquivos de ECG"
    },
    "data_hora_ecg": {
      "type": "string",
      "format": "date-time",
      "description": "Data e hora do carregamento do ECG"
    },
    "tempo_triagem_ecg_minutos": {
      "type": "number",
      "description": "Tempo em minutos entre triagem e ECG"
    },
    "analise_ecg_ia": {
      "type": "string",
      "description": "An\u00e1lise do ECG por intelig\u00eancia artificial"
    },
    "classificacao_risco": {
      "type": "object",
      "properties": {
        "cor": {
          "type": "string",
          "enum": [
            "Vermelha",
            "Laranja",
            "Amarela",
            "Verde",
            "Azul"
          ]
        },
        "tempo_atendimento_max": {
          "type": "string",
          "description": "Tempo m\u00e1ximo de espera"
        },
        "discriminadores": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "enfermeiro_nome": {
      "type": "string",
      "description": "Nome do enfermeiro respons\u00e1vel pela triagem"
    },
    "enfermeiro_coren": {
      "type": "string",
      "description": "N\u00famero COREN do enfermeiro"
    },
    "avaliacao_medica": {
      "type": "object",
      "properties": {
        "data_hora_avaliacao": {
          "type": "string",
          "format": "date-time"
        },
        "antecedentes": {
          "type": "string"
        },
        "quadro_atual": {
          "type": "string"
        },
        "hipoteses_diagnosticas": {
          "type": "string"
        },
        "diagnostico_confirmado": {
          "type": "string"
        },
        "observacoes": {
          "type": "string"
        }
      }
    },
    "medico_nome": {
      "type": "string",
      "description": "Nome do m\u00e9dico respons\u00e1vel pelo atendimento"
    },
    "medico_crm": {
      "type": "string",
      "description": "N\u00famero CRM do m\u00e9dico"
    },
    "prescricao_medicamentos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "medicamento": {
            "type": "string"
          },
          "dose": {
            "type": "string"
          },
          "via": {
            "type": "string"
          },
          "administrado": {
            "type": "boolean"
          }
        }
      }
    },
    "exames_solicitados": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "necessita_regulacao": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "Em Triagem",
        "Aguardando M\u00e9dico",
        "Em Atendimento",
        "Aguardando Regula\u00e7\u00e3o",
        "Transferido",
        "Alta",
        "\u00d3bito"
      ],
      "default": "Em Triagem"
    },
    "data_hora_encerramento": {
      "type": "string",
      "format": "date-time"
    },
    "destino": {
      "type": "string",
      "description": "Destino final do paciente"
    },
    "tempo_total_minutos": {
      "type": "number",
      "description": "Tempo total de atendimento em minutos"
    }
  },
  "required": [
    "nome_completo",
    "idade",
    "sexo"
  ]
}